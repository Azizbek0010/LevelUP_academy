# --- Core ---
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
LOG_LEVEL=debug

# --- PostgreSQL ---
# Локально (docker): строка ниже, DB_SSL=false.
# Общий Neon: DATABASE_URL=postgres://USER:PASS@HOST/DB?sslmode=require  + DB_SSL=true
DATABASE_URL=postgres://levelup:levelup@localhost:5432/levelup
DB_SSL=false

# --- Redis ---
# Локально (docker): строка ниже. Общий Redis Cloud: redis://default:PASS@HOST:PORT
REDIS_URL=redis://localhost:6379

# --- Auth (secret shared with auth module; payload: { sub, role, orgId, branchId }) ---
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=levelup

# --- SMTP (Mailpit in dev: web UI at http://localhost:8025) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@levelup.local

# --- SMS provider (empty in dev — messages are logged instead of sent) ---
SMS_API_URL=
SMS_API_TOKEN=

# --- Telegram bot (optional in dev — worker skips TG delivery if empty) ---
TELEGRAM_BOT_TOKEN=

# --- Due-soon reminder ---
DUE_SOON_REMINDER_DAYS=2

# --- Seeds ---
SEED_MAIN_ADMIN_PHONE=+998900000000
SEED_MAIN_ADMIN_PASSWORD=ChangeMe123!
