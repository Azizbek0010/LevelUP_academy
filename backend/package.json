{
  "name": "levelup-academy-backend",
  "version": "0.1.0",
  "private": true,
  "description": "LevelUp Academy — multi-tenant Educational CRM backend (Express + PostgreSQL + Redis + Socket.io + BullMQ)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node worker.js",
    "worker:dev": "node --watch worker.js",
    "migrate": "node-pg-migrate -j js -m src/db/migrations up",
    "migrate:down": "node-pg-migrate -j js -m src/db/migrations down",
    "migrate:create": "node-pg-migrate -j js -m src/db/migrations create",
    "seed": "node src/db/seeds/seed.js",
    "docs:md": "node scripts/generate-api-docs.js",
    "test": "node tests/mentor/run.js && node tests/student/run.js && node tests/parent/run.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^10.9.0",
    "grammy": "^1.33.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "rate-limiter-flexible": "^5.0.4",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "node-pg-migrate": "^7.8.0",
    "pino-pretty": "^13.0.0"
  }
}
