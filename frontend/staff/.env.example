# Frontend environment — LevelUp Academy Staff Panel
# Development: Vite proxy (/api → localhost:4000) is used automatically
# Production: Set VITE_API_URL to your Render backend URL

# VITE_API_URL — backend manzili (proxy orqali /api so'rovlari shu yerga yo'naltiriladi)
# VITE_USE_MOCKS=false — real backendga ulanish (mocksiz ishlash uchun)
#                 true  — localStorage'dagi mock ma'lumotlar bilan ishlash (default)

# Development (local backend):
# VITE_API_URL=http://localhost:4000
# VITE_USE_MOCKS=true

# Production (Render):
VITE_API_URL=https://levelup-academy-1.onrender.com
VITE_USE_MOCKS=true
