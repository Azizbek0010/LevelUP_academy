# Скопировать в .env (он в .gitignore).

# false — реальный бэкенд; true/не задано — демо-данные в памяти, бэкенд не вызывается.
VITE_USE_MOCKS=false

# Куда dev-прокси Vite шлёт /api. Без VITE_ префикса: серверная переменная,
# в браузер не попадает. Локальный бэкенд — http://localhost:4000.
DEV_API_PROXY=https://levelup-backend-ng1z.onrender.com

# В dev оставить ПУСТЫМ: иначе браузер пойдёт на бэкенд напрямую, в обход прокси,
# и refresh-cookie (SameSite=Lax) не отправится — сессия не подхватится.
# Заполняется только для production build.
# VITE_API_URL=

# Общий вход (панель member) — туда уходит логаут и редирект без сессии.
VITE_MEMBER_URL=http://localhost:5175
