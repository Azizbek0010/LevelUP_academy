{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/", "destination": "/landing", "permanent": true }
  ],
  "headers": [
    {
      "source": "/sitemap.xsl",
      "headers": [{ "key": "Content-Type", "value": "text/xsl; charset=utf-8" }]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
