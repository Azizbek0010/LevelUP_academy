{
  "permissions": {
    "allow": [
      "Read(//tmp/**)",
      "Bash(curl -s -m 5 http://localhost:4000/health)",
      "Bash(netstat -ano)",
      "Bash(curl -s -m 8 -w \"\\\\nHTTP:%{http_code}\\\\n\" http://localhost:4000/health)",
      "Bash(curl -s -m 10 -w \"\\\\nHTTP:%{http_code}\\\\n\" -X POST http://localhost:4000/api/auth/member/login -H \"Content-Type: application/json\" -d '{\"login\":\"demostud\",\"password\":\"123456\"}' -c /tmp/cookies.txt)",
      "Bash(tasklist //FI \"IMAGENAME eq node.exe\")",
      "Bash(docker --version)",
      "Bash(docker compose *)",
      "Bash(npm run *)",
      "Bash(curl -s -m 90 -w \"\\\\nHTTP:%{http_code}\\\\n\" https://levelup-backend-ng1z.onrender.com/health)",
      "Bash(curl -s -m 60 -i -X POST https://levelup-backend-ng1z.onrender.com/api/auth/member/login -H \"Content-Type: application/json\" -d '{\"login\":\"demostud\",\"password\":\"123456\"}')",
      "Bash(taskkill //PID 21436 //F)",
      "Bash(taskkill //PID 42808 //F)",
      "Bash(npm install *)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_network_requests"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"D:\\Все\\Рабочи стол\\LevelUp Academy\" pull --ff-only",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "cd \"D:\\Все\\Рабочи стол\\LevelUp Academy\" && python scripts/update-done.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
